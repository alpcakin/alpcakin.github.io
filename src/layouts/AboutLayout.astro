---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">

    <!-- About header -->
    <div class="about-header">
      <p class="about-label">About</p>
      <img src="/images/alp-cakin.jpeg" alt={SITE.author} class="about-photo" />
      <div class="about-rule"></div>
    </div>

    <section
      id="about"
      class="about-content app-prose mb-24 max-w-app prose-img:border-0"
    >
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .about-header {
    padding-top: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    margin-bottom: 1.5rem;
  }

  .about-label {
    font-family: var(--font-cartograph, monospace);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
    margin-bottom: 0.875rem;
  }

  .about-photo {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid color-mix(in srgb, var(--border) 60%, transparent);
    margin-bottom: 0.5rem;
  }

  .about-rule {
    display: none;
  }

  .about-content {
    position: relative;
  }
</style>
