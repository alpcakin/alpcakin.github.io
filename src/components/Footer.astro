---
import type { HTMLAttributes } from "astro/types";
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["footer-wrapper", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="h-px w-full bg-border/40"></div>

  <div class="app-layout py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <!-- Brand -->
      <div class="flex flex-col gap-2">
        <a href="/" class="footer-brand">
          {SITE.author}
        </a>
        <p class="text-xs text-foreground/40 max-w-xs leading-relaxed">
          {SITE.desc}
        </p>
      </div>

      <!-- Socials -->
      <div class="flex flex-col items-start gap-3 sm:items-end">
        <span class="text-[10px] tracking-widest uppercase text-foreground/30 select-none">
          Connect
        </span>
        <div class="flex items-center gap-2">
          {
            SOCIALS.map(social => (
              <LinkButton
                href={social.href}
                class="footer-social-btn"
                title={social.linkTitle}
                target="_blank"
                rel="noopener noreferrer"
              >
                <social.icon class="size-4 fill-none stroke-foreground/50 stroke-[1.5px] transition-colors duration-200 group-hover:stroke-accent" />
                <span class="sr-only">{social.linkTitle}</span>
              </LinkButton>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-border/20 flex items-center justify-between">
      <p class="text-xs text-foreground/30">
        &copy; {currentYear} {SITE.author}
      </p>
      <a
        href="/rss.xml"
        class="text-xs text-foreground/30 hover:text-accent transition-colors duration-200"
        title="RSS Feed"
      >
        RSS
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-wrapper {
    position: relative;
    background: color-mix(in srgb, var(--background) 95%, var(--muted));
  }

  .footer-brand {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--foreground);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .footer-brand:hover {
    color: var(--accent);
  }

  .footer-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .footer-social-btn:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
</style>
