---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";

import MobileMenu from "./MobileMenu.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-b-sm bg-accent px-4 py-2 text-sm font-medium text-background transition-all focus:top-0"
>
  Skip to content
</a>

<header id="main-header" class="sticky top-0 z-40 w-full transition-colors duration-300">
  <!-- Gold accent line -->
  <div class="h-[2px] w-full bg-accent/70"></div>

  <div class="header-scrolled-filter w-full">
    <div class="app-layout">
      <div
        id="top-nav-wrap"
        class="py-4 sm:py-5 relative w-full flex items-center justify-between transition-all duration-300"
      >
        <!-- Logo -->
        <a href="/" class="header-brand group">
          {SITE.author}
        </a>

        <!-- Nav -->
        <nav id="nav-menu" class="flex items-center sm:gap-1">
          <!-- Mobile hamburger -->
          <button
            id="menu-btn"
            class="hamburger-btn sm:hidden"
            aria-label="Open Menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <div class="hamburger-box">
              <span class="hamburger-line hamburger-line--1"></span>
              <span class="hamburger-line hamburger-line--2"></span>
              <span class="hamburger-line hamburger-line--3"></span>
            </div>
          </button>

          <!-- Desktop links -->
          <ul class="hidden sm:flex sm:flex-row sm:items-center sm:gap-1">
            <li>
              <a
                href="/about"
                class:list={["nav-link", { "nav-active": isActive("/about") }]}
                >About</a
              >
            </li>

            <!-- Separator -->
            <li class="flex items-center px-1" aria-hidden="true">
              <div class="h-3.5 w-px bg-border/50"></div>
            </li>

            <!-- Language toggle -->
            <li class="flex items-center">
              <div class="lang-toggle" id="lang-toggle-desktop">
                <span class="lang-option" data-lang="en">EN</span>
                <span class="lang-divider">/</span>
                <span class="lang-option" data-lang="tr">TR</span>
              </div>
            </li>

            <!-- Separator -->
            <li class="flex items-center px-1" aria-hidden="true">
              <div class="h-3.5 w-px bg-border/50"></div>
            </li>

            <li class="flex items-center">
              <button
                data-search-trigger
                class="nav-search-btn"
                title="Search (⌘K)"
                aria-label="Open search"
                aria-keyshortcuts="Meta+K"
              >
                <IconSearch class="size-4" />
                <kbd class="nav-kbd">⌘K</kbd>
              </button>
            </li>

            {
              SITE.lightAndDarkMode && (
                <li class="flex items-center">
                  <button
                    id="theme-btn"
                    class="nav-icon-btn relative"
                    title="Toggle light/dark"
                    aria-label="auto"
                    aria-live="polite"
                  >
                    <IconMoon class="absolute top-1/2 left-1/2 -translate-1/2 scale-100 rotate-0 transition-all duration-300 dark:scale-0 dark:-rotate-90" />
                    <IconSunHigh class="absolute top-1/2 left-1/2 -translate-1/2 scale-0 rotate-90 transition-all duration-300 dark:scale-100 dark:rotate-0" />
                  </button>
                </li>
              )
            }
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <!-- Bottom border on scroll -->
  <div
    id="header-border"
    class="opacity-0 transition-opacity duration-300 h-px w-full bg-border/30"
  >
  </div>

  <MobileMenu currentPath={currentPath} />
</header>

<style>
  #main-header {
    background: transparent;
  }

  :global(.header-scrolled) {
    background: color-mix(in srgb, var(--background) 88%, transparent) !important;
  }

  :global(.header-scrolled .header-scrolled-filter) {
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
  }

  /* ─── Brand / Logo ─── */
  .header-brand {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--foreground);
    transition: color 0.2s ease;
    position: relative;
    z-index: 20;
  }

  .header-brand:hover {
    color: var(--accent);
  }

  /* ─── Nav links ─── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.625rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--foreground);
    border-radius: 0.375rem;
    transition: color 0.15s ease, background-color 0.15s ease;
    letter-spacing: 0.01em;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-active {
    color: var(--accent);
  }

  .nav-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--foreground);
    transition: color 0.15s ease;
  }

  .nav-icon-btn:hover {
    color: var(--accent);
  }

  /* ─── Search button ─── */
  .nav-search-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--muted-foreground);
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 0.375rem;
    background: color-mix(in srgb, var(--muted) 50%, transparent);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .nav-search-btn:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .nav-kbd {
    font-family: inherit;
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    border-bottom-width: 2px;
    background: color-mix(in srgb, var(--background) 90%, transparent);
    color: var(--muted-foreground);
  }

  /* ─── Hamburger ─── */
  .hamburger-btn {
    position: relative;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.375rem;
    border: 1px solid transparent;
    background: transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
  }

  @media (min-width: 640px) {
    .hamburger-btn { display: none; }
  }

  .hamburger-btn:hover,
  .hamburger-btn[aria-expanded="true"] {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .hamburger-box {
    position: relative;
    width: 18px;
    height: 13px;
  }

  .hamburger-line {
    position: absolute;
    left: 0;
    display: block;
    width: 100%;
    height: 1.5px;
    border-radius: 2px;
    background: var(--foreground);
    transition: transform 0.3s ease, opacity 0.3s ease, top 0.3s ease, width 0.3s ease;
  }

  .hamburger-line--1 { top: 0; }
  .hamburger-line--2 { top: 6px; }
  .hamburger-line--3 { top: 12px; width: 65%; }

  .hamburger-btn[aria-expanded="true"] .hamburger-line { background: var(--accent); }
  .hamburger-btn[aria-expanded="true"] .hamburger-line--1 { top: 6px; transform: rotate(45deg); }
  .hamburger-btn[aria-expanded="true"] .hamburger-line--2 { opacity: 0; transform: scaleX(0); }
  .hamburger-btn[aria-expanded="true"] .hamburger-line--3 { top: 6px; width: 100%; transform: rotate(-45deg); }

  /* ─── Language toggle ─── */
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-radius: 0.375rem;
  }

  .lang-divider {
    color: var(--border);
    font-weight: 400;
  }

  .lang-option {
    color: var(--muted-foreground);
    cursor: pointer;
    transition: color 0.15s ease;
    padding: 0.1rem 0.15rem;
    border-radius: 0.2rem;
  }

  .lang-option:hover {
    color: var(--accent);
  }

  .lang-option.lang-active {
    color: var(--accent);
    font-weight: 700;
  }
</style>

<script>
  let headerCleanup: AbortController | null = null;
  let scrollCleanup: AbortController | null = null;

  function setupScrollPhysics() {
    if (scrollCleanup) scrollCleanup.abort();
    scrollCleanup = new AbortController();
    const { signal } = scrollCleanup;

    const header = document.getElementById("main-header");
    const navWrap = document.getElementById("top-nav-wrap");
    const borderLine = document.getElementById("header-border");

    if (!header || !navWrap || !borderLine) return;

    let rafPending = false;
    const handleScroll = () => {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 15;
        header.classList.toggle("header-scrolled", scrolled);
        navWrap.classList.toggle("sm:py-5", !scrolled);
        navWrap.classList.toggle("sm:py-3", scrolled);
        borderLine.classList.toggle("opacity-0", !scrolled);
        borderLine.classList.toggle("opacity-100", scrolled);
        rafPending = false;
      });
    };

    window.addEventListener("scroll", handleScroll, { passive: true, signal });
    handleScroll();
  }

  function setupMobileNav() {
    if (headerCleanup) headerCleanup.abort();
    headerCleanup = new AbortController();
    const { signal } = headerCleanup;

    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const backdrop = document.querySelector(".mobile-menu-backdrop");

    if (!menuBtn || !mobileMenu) return;

    const closeMenu = () => {
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", "Open Menu");
      mobileMenu.classList.remove("is-open");
      mobileMenu.setAttribute("aria-hidden", "true");
    };

    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        closeMenu();
      } else {
        menuBtn.setAttribute("aria-expanded", "true");
        menuBtn.setAttribute("aria-label", "Close Menu");
        mobileMenu.classList.add("is-open");
        mobileMenu.setAttribute("aria-hidden", "false");
      }
    }, { signal });

    if (backdrop) {
      backdrop.addEventListener("click", closeMenu, { signal });
      window.addEventListener("scroll", closeMenu, { passive: true, signal });
    }

    mobileMenu.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", closeMenu, { signal });
    });
  }

  function setupLangToggle() {
    const toggles = document.querySelectorAll<HTMLElement>(".lang-toggle");
    if (!toggles.length) return;

    const path = window.location.pathname;
    const isTR = path.startsWith("/tr");

    toggles.forEach(toggle => {
      const enBtn = toggle.querySelector<HTMLElement>('[data-lang="en"]');
      const trBtn = toggle.querySelector<HTMLElement>('[data-lang="tr"]');
      if (!enBtn || !trBtn) return;

      // Mark active
      enBtn.classList.toggle("lang-active", !isTR);
      trBtn.classList.toggle("lang-active", isTR);

      enBtn.addEventListener("click", () => {
        // /tr/posts/foo → /posts/foo
        const dest = path.replace(/^\/tr/, "") || "/";
        window.location.href = dest;
      });

      trBtn.addEventListener("click", () => {
        // /posts/foo → /tr/posts/foo
        const dest = isTR ? path : "/tr" + (path === "/" ? "" : path);
        window.location.href = dest;
      });
    });
  }

  setupScrollPhysics();
  setupMobileNav();
  setupLangToggle();

  document.addEventListener("astro:after-swap", () => {
    setupScrollPhysics();
    setupMobileNav();
    setupLangToggle();
  });
</script>
