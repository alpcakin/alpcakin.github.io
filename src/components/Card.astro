---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
  featured?: boolean;
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", featured = false, id, data, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;
const imageUrl = typeof ogImage === "string" ? ogImage : undefined;
---

<li class:list={["group border-b border-border/30 py-6 last:border-0", featured && "featured-post"]}>
  <div class="relative">
    <a
      href={getPath(id, filePath)}
      class="block focus-visible:outline-none rounded-sm"
      style={{ viewTransitionName: slugifyStr(String(title).replaceAll(".", "-")) }}
    >
      <!-- Expand clickable area -->
      <span class="absolute -inset-x-1 -inset-y-5 z-10" aria-hidden="true"></span>

      {imageUrl && (
        <div class="card-image-wrap">
          <img src={imageUrl} alt={String(title)} class="card-image" loading="lazy" />
        </div>
      )}

      <div class="flex items-baseline justify-between gap-6">
        <Heading class="editorial-title text-foreground transition-colors duration-200 group-hover:text-accent leading-snug">
          {featured && <span class="featured-mark" aria-label="Featured">★&nbsp;</span>}
          {title}
        </Heading>
        <Datetime
          pubDatetime={props.pubDatetime as string | Date}
          modDatetime={props.modDatetime as string | Date | null | undefined}
          class="relative z-20 shrink-0 pointer-events-none [&>svg]:hidden [&_time]:text-xs [&_time]:opacity-40 [&_time]:tabular-nums"
        />
      </div>

      <p class="relative z-20 mt-2 line-clamp-2 text-sm leading-relaxed text-foreground/55 pointer-events-auto select-text">
        {description}
      </p>
    </a>
  </div>
</li>

<style>
  .card-image-wrap {
    position: relative;
    z-index: 20;
    margin-bottom: 0.875rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border) 40%, transparent);
    aspect-ratio: 16 / 7;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.35s ease, opacity 0.25s ease;
    opacity: 0.88;
  }

  .group:hover .card-image {
    transform: scale(1.025);
    opacity: 1;
  }

  .editorial-title {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .editorial-title {
      font-size: 1.125rem;
    }
  }

  .featured-mark {
    color: var(--accent);
    font-style: normal;
  }

  .featured-post {
    border-color: color-mix(in srgb, var(--border) 50%, transparent);
  }
</style>
